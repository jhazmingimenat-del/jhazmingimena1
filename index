<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Gestión de Personal y Asistencia QR</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .card { border: none; box-shadow: 0 4px 6px rgba(0,0,0,0.1); border-radius: 12px; }
        .nav-pills .nav-link.active { background-color: #0d6efd; }
        #reader { width: 100%; max-width: 400px; margin: 0 auto; background: white; border-radius: 8px; overflow: hidden; }
        .table-responsive { max-height: 500px; overflow-y: auto; }
    </style>
</head>
<body>

<div class="container-fluid py-4">
    <header class="pb-3 mb-4 border-bottom d-flex justify-content-between align-items-center flex-wrap">
        <h1 class="fs-4 text-dark"><i class="bi bi-person-badge-fill text-primary"></i> Control de Personal & Asistencia</h1>
        <div>
            <button class="btn btn-success me-2" onclick="exportarBackup()"><i class="bi bi-download"></i> Exportar Backup (JS)</button>
            <button class="btn btn-outline-primary" onclick="abrirCamaraQR()"><i class="bi bi-qr-code-scan"></i> Escanear QR</button>
        </div>
    </header>

    <ul class="nav nav-pills mb-4" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pills-trabajadores-tab" data-bs-toggle="pill" data-bs-target="#pills-trabajadores" type="button" role="tab">Trabajadores</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pills-asistencia-tab" data-bs-toggle="pill" data-bs-target="#pills-asistencia" type="button" role="tab">Calendario de Asistencias</button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
        <div class="tab-pane fade show active" id="pills-trabajadores" role="tabpanel">
            <div class="card p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Listado de Colaboradores</h5>
                    <button class="btn btn-primary btn-sm" onclick="modalTrabajador()"><i class="bi bi-person-plus"></i> Nuevo Trabajador</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>DNI</th>
                                <th>Nombres y Apellidos</th>
                                <th>Género</th>
                                <th>Edad</th>
                                <th>Teléfono</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="tablaTrabajadores"></tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="pills-asistencia" role="tabpanel">
            <div class="card p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="card-title mb-0">Registro de Asistencias Diarias</h5>
                    <button class="btn btn-secondary btn-sm" onclick="modalAsistenciaManual()"><i class="bi bi-plus-circle"></i> Registro Manual</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Fecha y Hora</th>
                                <th>DNI</th>
                                <th>Trabajador</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody id="tablaAsistencias"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="qr-container" style="display:none;">
    <div id="reader"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://unpkg.com/html5-qrcode"></script>

<script>
// --- BASE DE DATOS INICIAL (20 REGISTROS GRABADOS) ---
let trabajadores = [
    { dni: "72418593", nombres: "Carlos Alberto", apellidos: "Mendoza Ruiz", genero: "Masculino", edad: 34, telefono: "981234567" },
    { dni: "45192837", nombres: "Ana Beatriz", apellidos: "Gómez Flores", genero: "Femenino", edad: 28, telefono: "955678123" },
    { dni: "10293847", nombres: "Luis Fernando", apellidos: "Castro Palacios", genero: "Masculino", edad: 42, telefono: "933456789" },
    { dni: "61524374", nombres: "María Elena", apellidos: "Quispe Mamani", genero: "Femenino", edad: 31, telefono: "912345678" },
    { dni: "08273645", nombres: "Jorge Luis", apellidos: "Herrera Díaz", genero: "Masculino", edad: 45, telefono: "966789123" },
    { dni: "73645281", nombres: "Claudia Sofía", apellidos: "Rojas Villanueva", genero: "Femenino", edad: 26, telefono: "944123789" },
    { dni: "29384756", nombres: "Javier Enrique", apellidos: "Salazar Torres", genero: "Masculino", edad: 39, telefono: "922852741" },
    { dni: "40596817", nombres: "Diana Carolina", apellidos: "Silva Vargas", genero: "Femenino", edad: 33, telefono: "977159357" },
    { dni: "51627384", nombres: "Ricardo Andrés", apellidos: "Morales Benítez", genero: "Masculino", edad: 50, telefono: "999369258" },
    { dni: "12547896", nombres: "Gabriela Alejandra", apellidos: "Gutiérrez Peña", genero: "Femenino", edad: 29, telefono: "988741256" },
    { dni: "33669922", nombres: "Alejandro José", apellidos: "Espinoza Ramos", genero: "Masculino", edad: 37, telefono: "911234567" },
    { dni: "48576921", nombres: "Patricia Noemí", apellidos: "Delgado Campos", genero: "Femenino", edad: 41, telefono: "935468172" },
    { dni: "70102030", nombres: "Roberto Carlos", apellidos: "Paredes Chávez", genero: "Masculino", edad: 24, telefono: "952147369" },
    { dni: "62718394", nombres: "Lucía Fernanda", apellidos: "Méndez Zavala", genero: "Femenino", edad: 35, telefono: "963258147" },
    { dni: "09182736", nombres: "Gustavo Adolfo", apellidos: "Farfán Ortiz", genero: "Masculino", edad: 48, telefono: "974125368" },
    { dni: "55443322", nombres: "Natalia Isabel", apellidos: "Campos Ríos", genero: "Femenino", edad: 27, telefono: "926357418" },
    { dni: "41728395", nombres: "Francisco Javier", apellidos: "Vega Córdoba",作 genero: "Masculino", edad: 53, telefono: "948152637" },
    { dni: "76859403", nombres: "Valeria Nicole", apellidos: "Cárdenas Cruz", genero: "Femenino", edad: 23, telefono: "919283746" },
    { dni: "22334455", nombres: "Manuel Antonio", apellidos: "Solís Guerrero", genero: "Masculino", edad: 46, telefono: "987654321" },
    { dni: "60504030", nombres: "Andrea del Pilar", apellidos: "Alva Montenegro", genero: "Femenino", edad: 32, telefono: "954781236" }
];

let asistencias = [
    { fecha: "2026-06-09 08:00", dni: "72418593", estado: "A Tiempo" },
    { fecha: "2026-06-09 08:15", dni: "45192837", estado: "Tardanza" }
];

let html5QrcodeScanner;

// --- INICIALIZACIÓN ---
document.addEventListener("DOMContentLoaded", () => {
    renderTrabajadores();
    renderAsistencias();
});

// --- RENDERIZADO DE TABLAS ---
function renderTrabajadores() {
    const tbody = document.getElementById("tablaTrabajadores");
    tbody.innerHTML = "";
    trabajadores.forEach((t, index) => {
        tbody.innerHTML += `
            <tr>
                <td><strong>${t.dni}</strong></td>
                <td>${t.nombres} ${t.apellidos}</td>
                <td><span class="badge ${t.genero==='Masculino'?'bg-info':'bg-danger'}">${t.genero}</span></td>
                <td>${t.edad} años</td>
                <td>${t.telefono}</td>
                <td class="text-center">
                    <button class="btn btn-warning btn-sm me-1" onclick="modalTrabajador(${index})"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-danger btn-sm" onclick="eliminarTrabajador(${index})"><i class="bi bi-trash"></i></button>
                </td>
            </tr>`;
    });
}

function renderAsistencias() {
    const tbody = document.getElementById("tablaAsistencias");
    tbody.innerHTML = "";
    asistencias.sort((a,b) => new Date(b.fecha) - new Date(a.fecha)).forEach((asist, index) => {
        const t = trabajadores.find(emp => emp.dni === asist.dni);
        const nombreCompleto = t ? `${t.nombres} ${t.apellidos}` : "Trabajador no registrado";
        const badgeColor = asist.estado === "A Tiempo" ? "bg-success" : (asist.estado === "Tardanza" ? "bg-warning text-dark" : "bg-danger");
        
        tbody.innerHTML += `
            <tr>
                <td>${asist.fecha}</td>
                <td>${asist.dni}</td>
                <td>${nombreCompleto}</td>
                <td><span class="badge ${badgeColor}">${asist.estado}</span></td>
                <td class="text-center">
                    <button class="btn btn-outline-warning btn-sm me-1" onclick="editarAsistencia(${index})"><i class="bi bi-pencil"></i></button>
                    <button class="btn btn-outline-danger btn-sm" onclick="eliminarAsistencia(${index})"><i class="bi bi-trash"></i></button>
                </td>
            </tr>`;
    });
}

// --- CRUD TRABAJADORES (SWEETALERT2) ---
async function modalTrabajador(index = null) {
    const esEdicion = index !== null;
    const t = esEdicion ? trabajadores[index] : { dni:'', nombres:'', apellidos:'', genero:'Masculino', edad:'', telefono:'' };

    const { value: formValues } = await Swal.fire({
        title: esEdicion ? 'Editar Trabajador' : 'Registrar Nuevo Trabajador',
        html: `
            <input id="swal-dni" class="swal2-input" placeholder="DNI" value="${t.dni}" ${esEdicion ? 'disabled' : ''}>
            <input id="swal-nombres" class="swal2-input" placeholder="Nombres" value="${t.nombres}">
            <input id="swal-apellidos" class="swal2-input" placeholder="Apellidos" value="${t.apellidos}">
            <select id="swal-genero" class="swal2-select">
                <option value="Masculino" ${t.genero==='Masculino'?'selected':''}>Masculino</option>
                <option value="Femenino" ${t.genero==='Femenino'?'selected':''}>Femenino</option>
            </select>
            <input id="swal-edad" type="number" class="swal2-input" placeholder="Edad" value="${t.edad}">
            <input id="swal-telefono" class="swal2-input" placeholder="Teléfono" value="${t.telefono}">
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Guardar',
        cancelButtonText: 'Cancelar',
        preConfirm: () => {
            const dni = document.getElementById('swal-dni').value.trim();
            const nombres = document.getElementById('swal-nombres').value.trim();
            const apellidos = document.getElementById('swal-apellidos').value.trim();
            const genero = document.getElementById('swal-genero').value;
            const edad = document.getElementById('swal-edad').value;
            const telefono = document.getElementById('swal-telefono').value.trim();

            if (!dni || !nombres || !apellidos || !edad || !telefono) {
                Swal.showValidationMessage('Por favor completa todos los campos');
                return false;
            }
            if (!esEdicion && trabajadores.some(emp => emp.dni === dni)) {
                Swal.showValidationMessage('Este DNI ya está registrado');
                return false;
            }
            return { dni, nombres, apellidos, genero, edad: parseInt(edad), telefono };
        }
    });

    if (formValues) {
        if (esEdicion) {
            trabajadores[index] = { ...trabajadores[index], ...formValues };
            Swal.fire('¡Actualizado!', 'Datos modificados correctamente.', 'success');
        } else {
            trabajadores.push(formValues);
            Swal.fire('¡Registrado!', 'Trabajador añadido con éxito.', 'success');
        }
        renderTrabajadores();
    }
}

function eliminarTrabajador(index) {
    Swal.fire({
        title: '¿Estás seguro?',
        text: `Se eliminará a ${trabajadores[index].nombres}. Esta acción no se puede deshacer.`,
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: 'Sí, eliminar',
        cancelButtonText: 'Cancelar'
    }).then((result) => {
        if (result.isConfirmed) {
            trabajadores.splice(index, 1);
            renderTrabajadores();
            Swal.fire('Eliminado', 'El registro ha sido borrado.', 'success');
        }
    });
}

// --- GESTIÓN INTERACTIVA DE ASISTENCIAS ---
async function modalAsistenciaManual() {
    let opcionesTrabajadores = trabajadores.map(t => `<option value="${t.dni}">${t.nombres} ${t.apellidos} (${t.dni})</option>`).join('');
    
    const { value: formValues } = await Swal.fire({
        title: 'Registro Manual de Asistencia',
        html: `
            <select id="asist-dni" class="swal2-select">${opcionesTrabajadores}</select>
            <select id="asist-estado" class="swal2-select">
                <option value="A Tiempo">A Tiempo</option>
                <option value="Tardanza">Tardanza</option>
                <option value="Falta">Falta</option>
            </select>
            <input id="asist-fecha" type="datetime-local" class="swal2-input" value="${new Date().toISOString().slice(0,16)}">
        `,
        showCancelButton: true,
        confirmButtonText: 'Registrar',
        preConfirm: () => {
            return {
                dni: document.getElementById('asist-dni').value,
                estado: document.getElementById('asist-estado').value,
                fecha: document.getElementById('asist-fecha').value.replace('T', ' ')
            }
        }
    });

    if (formValues) {
        asistencias.push(formValues);
        renderAsistencias();
        Swal.fire('Registrado', 'Asistencia procesada correctamente.', 'success');
    }
}

async function editarAsistencia(index) {
    const asist = asistencias[index];
    const { value: nuevoEstado } = await Swal.fire({
        title: 'Modificar Estado de Asistencia',
        input: 'select',
        inputOptions: { 'A Tiempo': 'A Tiempo', 'Tardanza': 'Tardanza', 'Falta': 'Falta' },
        inputValue: asist.estado,
        showCancelButton: true
    });

    if (nuevoEstado) {
        asistencias[index].estado = nuevoEstado;
        renderAsistencias();
        Swal.fire('Modificado', 'El estado ha sido actualizado.', 'success');
    }
}

function eliminarAsistencia(index) {
    asistencias.splice(index, 1);
    renderAsistencias();
    Swal.fire('Eliminado', 'Registro de asistencia borrado.', 'success');
}

// --- INTEGRACIÓN LECTOR QR CON CÁMARA MÓVIL ---
function abrirCamaraQR() {
    Swal.fire({
        title: 'Escanee el código QR del Trabajador',
        html: '<div id="scanner-view" style="width: 100%; height: 300px; background: #000; border-radius:8px;"></div>',
        showCancelButton: true,
        cancelButtonText: 'Cerrar Cámara',
        didOpen: () => {
            html5QrcodeScanner = new Html5Qrcode("scanner-view");
            const config = { fps: 10, qrbox: { width: 250, height: 250 } };
            
            // Iniciar cámara trasera automáticamente (ideal para móviles)
            html5QrcodeScanner.start(
                { facingMode: "environment" }, 
                config,
                (qrText) => { // Éxito al escanear
                    procesarQRAsistencia(qrText);
                    html5QrcodeScanner.stop();
                    Swal.close();
                },
                (errorMessage) => { /* Ignorar errores de escaneo continuo */ }
            ).catch(err => {
                document.getElementById('scanner-view').innerHTML = `<p class="text-white p-3 text-center">Error al acceder a la cámara. Asegúrate de dar los permisos correspondientes.</p>`;
            });
        },
        willClose: () => {
            if(html5QrcodeScanner && html5QrcodeScanner.isScanning) {
                html5QrcodeScanner.stop();
            }
        }
    });
}

function procesarQRAsistencia(dniEscanedo) {
    const t = trabajadores.find(emp => emp.dni === dniEscanedo.trim());
    if (!t) {
        Swal.fire('Error de Lectura', `El DNI "${dniEscanedo}" leído del QR no pertenece a ningún trabajador registrado.`, 'error');
        return;
    }

    const ahora = new Date();
    const horaLimite = new Date(); 
    horaLimite.setHours(8, 5, 0); // Ejemplo: Tolerancia hasta las 08:05 AM

    const estado = ahora > horaLimite ? "Tardanza" : "A Tiempo";
    const formatoFecha = ahora.toISOString().slice(0,10) + " " + ahora.toTimeString().slice(0,5);

    asistencias.push({ fecha: formatoFecha, dni: dniEscanedo, estado: estado });
    renderAsistencias();

    Swal.fire({
        icon: 'success',
        title: `Asistencia Registrada`,
        text: `${t.nombres} ${t.apellidos} - Estado: ${estado}`,
        timer: 3000
    });
}

// --- EXPORTAR COPIA DE SEGURIDAD (BACKUP .JS) ---
function exportarBackup() {
    const dataBackup = `/** BACKUP SISTEMA DE GESTIÓN **/\nconst dataTrabajadores = ${JSON.stringify(trabajadores, null, 2)};\nconst dataAsistencias = ${JSON.stringify(asistencias, null, 2)};`;
    
    const blob = new Blob([dataBackup], { type: "text/javascript" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = `backup_sistema_${new Date().toISOString().slice(0,10)}.js`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
}
</script>
